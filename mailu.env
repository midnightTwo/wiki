# =====================================================
# Mailu — основная конфигурация для kmr-mail.online
# =====================================================
# Документация: https://mailu.io/2024.06/configuration.html

# ---- Основные настройки ----

# Секретный ключ (ОБЯЗАТЕЛЬНО ЗАМЕНИ на свой!)
# Сгенерируй: python3 -c "import secrets; print(secrets.token_hex(16))"
SECRET_KEY=CHANGE_ME_GENERATE_SECRET_KEY

# Домен для почты
DOMAIN=kmr-mail.online

# Хостнейм почтового сервера (MX-запись должна указывать сюда)
HOSTNAMES=mail.kmr-mail.online

# Что показывать на главной странице
SITENAME=KMR Mail

# URL вебсайта
WEBSITE=https://mail.kmr-mail.online

# ---- Сеть ----

# IP адрес сервера (ЗАМЕНИ на реальный IP твоего VPS!)
BIND_ADDRESS4=0.0.0.0

# Подсеть Docker
SUBNET=192.168.203.0/24

# ---- TLS / SSL ----

# Автоматический сертификат Let's Encrypt
TLS_FLAVOR=letsencrypt

# ---- Веб-интерфейсы ----

# Включить панель администратора
ADMIN=true

# Админка доступна по /admin
WEB_ADMIN=/admin

# Webmail доступен по /webmail
WEB_WEBMAIL=/webmail

# Тип webmail
WEBMAIL=roundcube

# ---- Почтовые протоколы ----

# Включаем IMAP и SMTP
IMAP_AUTH=true

# Включить POP3 (необязательно)
POP3=false

# ---- Пользователи и аутентификация ----

# Начальный пароль админа (ОБЯЗАТЕЛЬНО ЗАМЕНИ!)
# Установи при первой инициализации через команду:
# docker compose exec admin flask mailu admin admin kmr-mail.online YOUR_PASSWORD
INITIAL_ADMIN_ACCOUNT=admin
INITIAL_ADMIN_DOMAIN=kmr-mail.online
INITIAL_ADMIN_PW=himarra228
INITIAL_ADMIN_MODE=ifmissing

# ---- Безопасность ----

# Режим авторизации
AUTH_RATELIMIT_IP=60/hour
AUTH_RATELIMIT_USER=100/day

# Ограничение отправки (защита от спама с твоего сервера)
MESSAGE_RATELIMIT=200/day
MESSAGE_SIZE_LIMIT=50000000

# ---- Антиспам (Rspamd) ----

# Включить антиспам
ANTISPAM=rspamd

# ---- Логирование ----

LOG_LEVEL=WARNING

# ---- Хранение ----

# Путь к данным в контейнерах
# (volumes монтируются в docker-compose.yml)

# ---- Дополнительно ----

# Часовой пояс
TZ=Europe/Kiev

# Отключить IPv6 если не нужен
DISABLE_IPV6=true

# Postmaster
POSTMASTER=admin

# Wildcard senders (по умолчанию выключено)
WILDCARD_SENDERS=

# Режим (для production ставь "production")
COMPOSE_PROJECT_NAME=mailu

# Fetch mail (получение почты с других серверов)
FETCHMAIL_ENABLED=false

# ---- DKIM ----
# DKIM ключи генерируются автоматически при первом запуске
# Найдёшь их в /mailu/dkim/
# Содержимое нужно будет добавить в DNS
